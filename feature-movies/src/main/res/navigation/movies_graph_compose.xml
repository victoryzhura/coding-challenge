<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/movies_graph_compose"
    app:startDestination="@id/moviesFragmentCompose">

    <fragment
        android:id="@+id/moviesFragmentCompose"
        android:name="app.bettermetesttask.movies.sections.compose.MoviesComposeFragment">

        <deepLink app:uri="@string/movies_deep_link_compose" />
        <action
            android:id="@+id/action_moviesFragmentCompose_to_detailMovieFragmentCompose"
            app:destination="@id/detailMovieFragmentCompose" />
    </fragment>

    <fragment
        android:id="@+id/detailMovieFragmentCompose"
        android:name="app.bettermetesttask.movies.sections.compose.details.DetailMovieComposeFragment">
        <argument
            android:name="movieId"
            app:argType="integer" />
    </fragment>
</navigation>